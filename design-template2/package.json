{
  "name": "design-template2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "copy:flowbite": "node scripts/copy-flowbite.js",
    "build": "npm run build:css && npm run copy:flowbite",
    "watch": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/forms": "^0.5.10",
    "flowbite": "^4.0.1",
    "tailwindcss": "^4.2.2"
  }
}
