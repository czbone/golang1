{
  "name": "design-template1",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "copy:preline": "node scripts/copy-preline.js",
    "build": "npm run build:css && npm run copy:preline",
    "watch": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/forms": "^0.5.10",
    "preline": "^3.2.3",
    "tailwindcss": "^4.2.2"
  }
}
